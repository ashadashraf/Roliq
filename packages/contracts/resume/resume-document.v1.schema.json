{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.roliq.com/resume/resume-document.v1.schema.json",
  "title": "Roliq Resume Document v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "documentId",
    "createdAt",
    "source",
    "candidate",
    "summary",
    "skills",
    "experience",
    "education",
    "projects",
    "certifications",
    "languages",
    "links",
    "review"
  ],
  "properties": {
    "schemaVersion": { "const": "resume-document.v1" },
    "documentId": { "$ref": "#/$defs/uuid" },
    "createdAt": { "type": "string", "format": "date-time" },
    "source": { "$ref": "#/$defs/source" },
    "candidate": { "$ref": "#/$defs/candidate" },
    "summary": {
      "oneOf": [{ "$ref": "#/$defs/stringFact" }, { "type": "null" }]
    },
    "skills": {
      "type": "array",
      "maxItems": 200,
      "items": { "$ref": "#/$defs/skill" }
    },
    "experience": {
      "type": "array",
      "maxItems": 100,
      "items": { "$ref": "#/$defs/experience" }
    },
    "education": {
      "type": "array",
      "maxItems": 50,
      "items": { "$ref": "#/$defs/education" }
    },
    "projects": {
      "type": "array",
      "maxItems": 100,
      "items": { "$ref": "#/$defs/project" }
    },
    "certifications": {
      "type": "array",
      "maxItems": 100,
      "items": { "$ref": "#/$defs/certification" }
    },
    "languages": {
      "type": "array",
      "maxItems": 50,
      "items": { "$ref": "#/$defs/language" }
    },
    "links": {
      "type": "array",
      "maxItems": 50,
      "items": { "$ref": "#/$defs/link" }
    },
    "review": { "$ref": "#/$defs/documentReview" }
  },
  "$defs": {
    "uuid": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-8][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "warning": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "severity", "message"],
      "properties": {
        "code": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]{1,63}$" },
        "severity": { "type": "string", "enum": ["info", "warning", "error"] },
        "message": { "type": "string", "minLength": 1, "maxLength": 500 }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceSha256", "excerpt"],
      "properties": {
        "sourceSha256": { "$ref": "#/$defs/sha256" },
        "page": { "type": "integer", "minimum": 1, "maximum": 10000 },
        "paragraphIndex": { "type": "integer", "minimum": 0 },
        "startOffset": { "type": "integer", "minimum": 0 },
        "endOffset": { "type": "integer", "minimum": 1 },
        "excerpt": { "type": "string", "minLength": 1, "maxLength": 1000 }
      },
      "anyOf": [
        {
          "properties": { "page": { "type": "integer" } },
          "required": ["page"]
        },
        {
          "properties": { "paragraphIndex": { "type": "integer" } },
          "required": ["paragraphIndex"]
        },
        {
          "properties": {
            "startOffset": { "type": "integer" },
            "endOffset": { "type": "integer" }
          },
          "required": ["startOffset", "endOffset"]
        }
      ]
    },
    "factMetadata": {
      "type": "object",
      "required": [
        "origin",
        "confidence",
        "reviewState",
        "evidence",
        "warnings"
      ],
      "properties": {
        "origin": { "type": "string", "enum": ["extracted", "user"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "reviewState": {
          "type": "string",
          "enum": ["unreviewed", "confirmed", "corrected", "rejected"]
        },
        "evidence": {
          "type": "array",
          "maxItems": 20,
          "items": { "$ref": "#/$defs/evidence" }
        },
        "warnings": {
          "type": "array",
          "maxItems": 20,
          "items": { "$ref": "#/$defs/warning" }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "origin": { "const": "extracted" } },
            "required": ["origin"]
          },
          "then": {
            "properties": { "evidence": { "type": "array", "minItems": 1 } }
          }
        },
        {
          "if": {
            "properties": { "origin": { "const": "user" } },
            "required": ["origin"]
          },
          "then": {
            "properties": {
              "confidence": { "const": 1 },
              "reviewState": { "const": "corrected" }
            }
          }
        }
      ]
    },
    "stringFact": {
      "type": "object",
      "allOf": [
        { "$ref": "#/$defs/factMetadata" },
        {
          "type": "object",
          "required": ["value"],
          "properties": {
            "value": { "type": "string", "minLength": 1, "maxLength": 10000 },
            "normalizedValue": {
              "type": "string",
              "minLength": 1,
              "maxLength": 10000
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "dateFact": {
      "type": "object",
      "allOf": [
        { "$ref": "#/$defs/factMetadata" },
        {
          "type": "object",
          "required": ["value"],
          "properties": {
            "value": {
              "type": "string",
              "pattern": "^(19|20)[0-9]{2}(-(?:0[1-9]|1[0-2]))?(-(?:0[1-9]|[12][0-9]|3[01]))?$"
            },
            "precision": { "type": "string", "enum": ["year", "month", "day"] }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "booleanFact": {
      "type": "object",
      "allOf": [
        { "$ref": "#/$defs/factMetadata" },
        {
          "type": "object",
          "required": ["value"],
          "properties": { "value": { "type": "boolean" } }
        }
      ],
      "unevaluatedProperties": false
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "resumeId",
        "sourceVersionId",
        "fileObjectId",
        "contentSha256",
        "mediaType",
        "pageCount"
      ],
      "properties": {
        "resumeId": { "$ref": "#/$defs/uuid" },
        "sourceVersionId": { "$ref": "#/$defs/uuid" },
        "fileObjectId": { "$ref": "#/$defs/uuid" },
        "contentSha256": { "$ref": "#/$defs/sha256" },
        "mediaType": {
          "type": "string",
          "enum": [
            "application/pdf",
            "application/vnd.openxmlformats-officedocument.wordprocessingml.document"
          ]
        },
        "pageCount": { "type": "integer", "minimum": 1, "maximum": 25 }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "fullName": { "$ref": "#/$defs/stringFact" },
        "headline": { "$ref": "#/$defs/stringFact" },
        "email": { "$ref": "#/$defs/stringFact" },
        "phone": { "$ref": "#/$defs/stringFact" },
        "location": { "$ref": "#/$defs/stringFact" }
      }
    },
    "skill": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name"],
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "name": { "$ref": "#/$defs/stringFact" },
        "category": { "$ref": "#/$defs/stringFact" }
      }
    },
    "experience": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "company", "title", "highlights"],
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "company": { "$ref": "#/$defs/stringFact" },
        "title": { "$ref": "#/$defs/stringFact" },
        "location": { "$ref": "#/$defs/stringFact" },
        "startDate": { "$ref": "#/$defs/dateFact" },
        "endDate": { "$ref": "#/$defs/dateFact" },
        "isCurrent": { "$ref": "#/$defs/booleanFact" },
        "summary": { "$ref": "#/$defs/stringFact" },
        "highlights": {
          "type": "array",
          "maxItems": 50,
          "items": { "$ref": "#/$defs/stringFact" }
        }
      }
    },
    "education": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "institution"],
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "institution": { "$ref": "#/$defs/stringFact" },
        "degree": { "$ref": "#/$defs/stringFact" },
        "fieldOfStudy": { "$ref": "#/$defs/stringFact" },
        "startDate": { "$ref": "#/$defs/dateFact" },
        "endDate": { "$ref": "#/$defs/dateFact" },
        "grade": { "$ref": "#/$defs/stringFact" }
      }
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "highlights", "technologies"],
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "name": { "$ref": "#/$defs/stringFact" },
        "description": { "$ref": "#/$defs/stringFact" },
        "startDate": { "$ref": "#/$defs/dateFact" },
        "endDate": { "$ref": "#/$defs/dateFact" },
        "highlights": {
          "type": "array",
          "maxItems": 50,
          "items": { "$ref": "#/$defs/stringFact" }
        },
        "technologies": {
          "type": "array",
          "maxItems": 100,
          "items": { "$ref": "#/$defs/stringFact" }
        }
      }
    },
    "certification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name"],
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "name": { "$ref": "#/$defs/stringFact" },
        "issuer": { "$ref": "#/$defs/stringFact" },
        "issuedDate": { "$ref": "#/$defs/dateFact" },
        "expiryDate": { "$ref": "#/$defs/dateFact" },
        "credentialId": { "$ref": "#/$defs/stringFact" },
        "url": { "$ref": "#/$defs/stringFact" }
      }
    },
    "language": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name"],
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "name": { "$ref": "#/$defs/stringFact" },
        "proficiency": { "$ref": "#/$defs/stringFact" }
      }
    },
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "url"],
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "label": { "$ref": "#/$defs/stringFact" },
        "url": { "$ref": "#/$defs/stringFact" }
      }
    },
    "documentReview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "revision", "warnings"],
      "properties": {
        "state": { "type": "string", "enum": ["needs_review", "reviewed"] },
        "revision": { "type": "integer", "minimum": 1 },
        "warnings": {
          "type": "array",
          "maxItems": 100,
          "items": { "$ref": "#/$defs/warning" }
        },
        "reviewedAt": { "type": "string", "format": "date-time" },
        "reviewedBy": { "$ref": "#/$defs/uuid" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "state": { "const": "reviewed" } },
            "required": ["state"]
          },
          "then": {
            "properties": {
              "reviewedAt": { "type": "string", "format": "date-time" },
              "reviewedBy": { "$ref": "#/$defs/uuid" }
            },
            "required": ["reviewedAt", "reviewedBy"]
          }
        }
      ]
    }
  }
}
