{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.roliq.com/events/resume.parse.completed.v1.json",
  "title": "resume.parse.completed.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventType",
    "eventVersion",
    "eventId",
    "occurredAt",
    "correlationId",
    "organizationId",
    "parsingJobId",
    "resumeId",
    "sourceVersionId",
    "resultArtifact",
    "outputSchemaVersion",
    "attempt"
  ],
  "properties": {
    "eventType": { "const": "resume.parse.completed" },
    "eventVersion": { "const": 1 },
    "eventId": { "type": "string", "format": "uuid" },
    "occurredAt": { "type": "string", "format": "date-time" },
    "correlationId": { "type": "string", "format": "uuid" },
    "organizationId": { "type": "string", "format": "uuid" },
    "parsingJobId": { "type": "string", "format": "uuid" },
    "resumeId": { "type": "string", "format": "uuid" },
    "sourceVersionId": { "type": "string", "format": "uuid" },
    "resultArtifact": {
      "$ref": "https://contracts.roliq.com/common/artifact-pointer.v1.schema.json"
    },
    "extractionArtifact": {
      "$ref": "https://contracts.roliq.com/common/artifact-pointer.v1.schema.json"
    },
    "outputSchemaVersion": { "const": "resume-document.v1" },
    "attempt": { "type": "integer", "minimum": 1, "maximum": 3 }
  }
}
